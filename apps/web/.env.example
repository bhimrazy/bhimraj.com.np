# Resend — newsletter subscriptions + transactional/feedback email
# https://resend.com/api-keys  (server-side only — never NEXT_PUBLIC)
RESEND_API_KEY=re_your_api_key_here
# Audience to add subscribers to: https://resend.com/audiences
RESEND_AUDIENCE_ID=your_audience_id_here
# Verified sender. Requires domain verification in Resend (SPF + DKIM DNS).
RESEND_FROM_EMAIL=Bhimraj Yadav <hello@bhimraj.com.np>
# Where site feedback notifications are delivered (your inbox).
FEEDBACK_NOTIFY_EMAIL=contact@bhimraj.com.np

# Google Analytics
# Get your GA4 measurement ID from Google Analytics dashboard
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_ANALYTICS=G-XXXXXXXXXX

# PostHog — product analytics (pageviews, autocapture, custom events)
# Project API key + host from https://app.posthog.com/settings/project
# Host is region-specific: https://us.i.posthog.com or https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# YouTube API
# Optional: YouTube API URL for fetching channel videos
# Get API key from https://console.cloud.google.com/
# Format: https://youtube.googleapis.com/youtube/v3/search?part=snippet&channelId=YOUR_CHANNEL_ID&maxResults=5&order=viewCount&key=YOUR_API_KEY
YOUTUBE_API_URL=https://youtube.googleapis.com/youtube/v3/search?part=snippet&channelId=YOUR_CHANNEL_ID&maxResults=5&order=viewCount&key=YOUR_API_KEY
