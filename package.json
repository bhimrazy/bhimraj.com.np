{
  "name": "bhimraj.com.np",
  "version": "1.0.0",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "sync": "turbo run sync --filter=@bhimrazy/github",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format:write": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check && turbo run build",
    "knip": "turbo run knip",
    "email:preview": "turbo run email:preview --filter=web",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "husky": "9.1.7",
    "lint-staged": "17.0.6",
    "turbo": "2.5.6",
    "typescript": "6.0.3"
  }
}
